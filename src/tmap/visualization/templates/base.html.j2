{#
  Base Template - Unified visualization shell (inline + fetch modes)

  Supports:
  - Inline mode for self-contained HTML output (to_html / write_html)
  - Fetch mode for static/server output (write_static / serve)

  Color columns are loaded lazily on demand.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background: {{ background_color }};
      color: #e0e0e0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    #canvas {
      width: 100vw;
      height: 100vh;
      display: block;
    }
    #title {
      position: fixed;
      top: 12px;
      left: 12px;
      padding: 6px 10px;
      border-radius: 6px;
      background: rgba(14, 14, 18, 0.7);
      border: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      font-size: 14px;
      letter-spacing: 0.4px;
      z-index: 120;
    }
    /* Legend (rendered inside color panel) */
    #legend-title { font-weight: 600; margin-bottom: 6px; }
    .legend-gradient { height: 10px; border-radius: 4px; border: 1px solid #fff; }
    .legend-range { display: flex; justify-content: space-between; font-size: 11px; margin-top: 4px; }
    .legend-item { display: flex; align-items: center; gap: 8px; margin: 2px 0; }
    .legend-swatch { width: 12px; height: 12px; border-radius: 3px; border: 1px solid #fff; }
    #tooltip {
      position: fixed;
      pointer-events: none;
      background: rgba(0, 0, 0, 0.7);
      border: 1px solid #333;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 12px;
      color: #e0e0e0;
      width: 240px;
      display: none;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
      z-index: 130;
    }
    #tooltip.visible { display: block; }
    #tooltip .label { font-weight: 700; margin-bottom: 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #tooltip .row { display: flex; justify-content: space-between; gap: 12px; margin: 2px 0; }
    #tooltip .key { color: #9ca3af; flex-shrink: 0; }
    #tooltip .value { color: #e5e7eb; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
    #loading {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: {{ background_color }};
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }
    #loading.hidden { display: none; }
    #loading-text { font-size: 18px; margin-bottom: 20px; }
    #progress-bar { width: 300px; height: 8px; background: rgba(255,255,255,0.2); border-radius: 4px; overflow: hidden; }
    #progress-fill { height: 100%; background: #4a9eff; width: 0%; transition: width 0.2s; }
    #progress-text { margin-top: 10px; font-size: 14px; color: #9ca3af; }

    /* Card stack - pinned cards from single clicks */
    #card-stack {
      position: fixed;
      top: 52px;
      left: 12px;
      z-index: 100;
      --card-width: 320px;
      --card-body-max-height: 420px;
    }
    #card-stack.hidden { display: none; }
    .card {
      width: var(--card-width);
      background: rgba(14, 14, 18, 0.86);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 12px;
      color: #e0e0e0;
      font-size: 12px;
      box-shadow: 0 12px 32px rgba(0,0,0,0.5);
      position: relative;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
    }
    .card-resize-handle {
      position: absolute;
      right: -2px;
      bottom: -2px;
      width: 16px;
      height: 16px;
      cursor: nwse-resize;
      z-index: 2;
      touch-action: none;
    }
    .card-resize-handle::before {
      content: "";
      position: absolute;
      right: 3px;
      bottom: 3px;
      width: 9px;
      height: 9px;
      border-radius: 999px;
      border-right: 2px solid rgba(255, 255, 255, 0.28);
      border-bottom: 2px solid rgba(255, 255, 255, 0.28);
    }
    .card-resize-handle:hover::before {
      border-right-color: rgba(74, 158, 255, 0.95);
      border-bottom-color: rgba(74, 158, 255, 0.95);
    }
    body.card-resizing {
      cursor: nwse-resize;
      user-select: none;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
      padding-bottom: 8px;
      border-bottom: 1px solid #333;
    }
    .card-nav {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: #9ca3af;
    }
    .card-nav button {
      background: #333;
      border: 1px solid #555;
      color: #fff;
      width: 22px;
      height: 22px;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      padding: 0;
    }
    .card-nav button:hover { background: #444; }
    .card-nav button:disabled { opacity: 0.3; cursor: not-allowed; }
    .card-close {
      background: transparent;
      border: none;
      color: #666;
      font-size: 18px;
      cursor: pointer;
      padding: 0 0 0 8px;
      line-height: 1;
    }
    .card-close:hover { color: #fff; }
    .card-minimize {
      background: transparent;
      border: none;
      color: #666;
      font-size: 14px;
      cursor: pointer;
      padding: 0 4px;
      line-height: 1;
    }
    .card-minimize:hover { color: #fff; }
    .card.minimized .card-body { display: none; }
    .card.minimized { padding: 8px 12px; }
    .card.minimized .card-header { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .card-body {
      overflow-y: auto;
      max-height: var(--card-body-max-height);
      padding-right: 2px;
    }
    .card-label {
      font-weight: 700;
      margin-bottom: 8px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin: 4px 0;
    }
    .card-row .key { color: #9ca3af; flex-shrink: 0; font-size: 11px; }
    .card-row .value {
      color: #e5e7eb;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
      flex: 1;
      text-align: right;
    }
    .card-copy-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 4px 0;
      background: #1a1a1a;
      padding: 6px 8px;
      border-radius: 4px;
    }
    .card-copy-row .key { color: #9ca3af; flex-shrink: 0; font-size: 11px; }
    .card-copy-row .value {
      color: #e5e7eb;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
      flex: 1;
      font-family: monospace;
      font-size: 11px;
    }
    .card-copy-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 3px 8px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 10px;
      flex-shrink: 0;
      font-weight: 500;
    }
    .card-copy-btn:hover { background: #3a8eef; }
    .card-copy-btn.copied { background: #22c55e; }
    /* Structure rendering for SMILES tooltips and cards */
    #tooltip .structure-container {
      width: 240px;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #tooltip .structure-container.hidden { display: none; }
    #tooltip #structure-svg { width: 240px; height: 200px; }
    .card .card-structure-container {
      display: flex;
      width: 100%;
      height: 200px;
      background: #fff;
      border-radius: 4px;
      margin-bottom: 8px;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
    }
    .card .card-structure-container.hidden { display: none; }
    .card #card-structure-svg { width: 100%; height: 200px; }
    /* Image rendering for tooltips and cards */
    #tooltip .image-container {
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #tooltip .image-container.hidden { display: none; }
    #tooltip .image-container img {
      image-rendering: pixelated;
      border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.3);
    }
    .card .card-image-container {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 8px;
    }
    .card .card-image-container.hidden { display: none; }
    .card .card-image-container img {
      image-rendering: pixelated;
      border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.3);
    }

    /* Protein / 3D structure viewer in cards */
    .card .card-structure-container .structure-loading {
      color: #666;
      font-size: 11px;
    }
    .card .card-structure-container .structure-error {
      color: #888;
      font-size: 11px;
      text-align: center;
      padding: 8px;
    }
    .card .card-structure-container .viewer-3d {
      width: 100%;
      height: 100%;
    }
    .uniprot-link {
      color: #4a9eff;
      text-decoration: none;
    }
    .uniprot-link:hover { text-decoration: underline; }
    .protein-meta-row {
      display: flex;
      gap: 4px;
      font-size: 11px;
      color: #ccc;
      padding: 2px 0;
    }
    .protein-meta-row .meta-key { color: #888; min-width: 60px; }
    .protein-meta-row .meta-val { color: #e0e0e0; word-break: break-word; }

    /* Export panel - bottom-left */
    #export-panel {
      position: fixed;
      bottom: 68px;
      left: 12px;
      background: rgba(0, 0, 0, 0.9);
      border: 1px solid #444;
      border-radius: 8px;
      padding: 12px 16px;
      color: #e0e0e0;
      font-size: 12px;
      z-index: 100;
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
      min-width: 280px;
    }
    #export-panel.hidden { display: none; }
    .export-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .export-title { font-weight: 600; font-size: 13px; }
    .export-close {
      background: transparent;
      border: none;
      color: #666;
      font-size: 16px;
      cursor: pointer;
      padding: 0;
    }
    .export-close:hover { color: #fff; }
    .export-columns {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 12px;
      margin-bottom: 12px;
      padding: 8px;
      background: #1a1a1a;
      border-radius: 4px;
      max-width: 400px;
    }
    .export-columns label {
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      font-size: 11px;
    }
    .export-columns input[type="checkbox"] { cursor: pointer; }
    .export-actions {
      display: flex;
      gap: 8px;
    }
    .export-btn {
      background: #4a9eff;
      border: none;
      color: #fff;
      padding: 6px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
    }
    .export-btn:hover { background: #3a8eef; }
    .export-btn.secondary {
      background: #333;
      border: 1px solid #555;
    }
    .export-btn.secondary:hover { background: #444; }
    /* ── Filter Sidebar (Embedding Atlas-style) ── */
    .fs-header {
      padding: 14px 16px 10px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }
    .fs-title { font-weight: 600; font-size: 13px; color: #e0e0e0; }
    #fs-count { flex: 1; text-align: right; font-size: 11px; color: #888; }
    #fs-clear-all {
      padding: 3px 8px;
      border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: #888;
      font-size: 10px;
      cursor: pointer;
    }
    #fs-clear-all:hover { background: rgba(255,255,255,0.08); color: #aaa; }
    #fs-clear-all.hidden { display: none; }
    #fs-close {
      width: 24px; height: 24px;
      border: none; background: transparent;
      color: #666; font-size: 14px; cursor: pointer;
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
    }
    #fs-close:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .fs-section { border-bottom: 1px solid rgba(255,255,255,0.04); }
    .fs-section-head {
      padding: 10px 16px;
      font-size: 11px; font-weight: 600; color: #aaa;
      cursor: pointer;
      display: flex; align-items: center; justify-content: space-between;
      user-select: none;
    }
    .fs-section-head:hover { background: rgba(255,255,255,0.02); }
    .fs-chevron { font-size: 8px; color: #666; transition: transform 0.2s; }
    .fs-section.collapsed .fs-section-body { display: none; }
    .fs-section.collapsed .fs-chevron { transform: rotate(-90deg); }
    .fs-section-body { padding: 0 16px 12px; }
    /* Categorical bars */
    .fs-bar-row {
      display: flex; align-items: center; gap: 8px;
      padding: 3px 0; cursor: pointer; font-size: 11px; border-radius: 3px;
    }
    .fs-bar-row:hover { background: rgba(255,255,255,0.03); }
    .fs-bar-row.deselected { opacity: 0.3; }
    .fs-bar-label {
      width: 100px; overflow: hidden; text-overflow: ellipsis;
      white-space: nowrap; color: #ccc; flex-shrink: 0;
    }
    .fs-bar-track {
      flex: 1; height: 14px;
      background: rgba(255,255,255,0.04); border-radius: 2px;
      position: relative; overflow: hidden;
    }
    .fs-bar-total {
      position: absolute; top: 0; left: 0; height: 100%;
      background: rgba(255,255,255,0.08); border-radius: 2px;
    }
    .fs-bar-selected {
      position: absolute; top: 0; left: 0; height: 100%;
      background: #4a9eff; border-radius: 2px; transition: width 0.15s;
    }
    .fs-bar-count {
      font-size: 10px; color: #666;
      min-width: 70px; text-align: right; white-space: nowrap;
    }
    .fs-show-more {
      font-size: 10px; color: #4a9eff; cursor: pointer;
      padding: 4px 0; user-select: none;
    }
    .fs-show-more:hover { text-decoration: underline; }
    /* Histogram */
    .fs-histogram {
      position: relative; height: 80px;
      display: flex; align-items: flex-end; gap: 1px; margin-bottom: 4px;
    }
    .fs-hist-bar {
      flex: 1; background: rgba(255,255,255,0.12);
      border-radius: 1px 1px 0 0; min-width: 2px; transition: background 0.1s;
    }
    .fs-hist-bar.in-brush { background: #4a9eff; }
    .fs-hist-brush {
      position: absolute; top: 0; height: 100%;
      background: rgba(74, 158, 255, 0.15);
      border-left: 2px solid rgba(74, 158, 255, 0.5);
      border-right: 2px solid rgba(74, 158, 255, 0.5);
      pointer-events: none; display: none;
    }
    .fs-hist-overlay {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      cursor: crosshair;
    }
    .fs-hist-axis {
      display: flex; justify-content: space-between;
      font-size: 9px; color: #666; padding: 0 2px;
    }
    .fs-hist-range {
      text-align: center; font-size: 10px; color: #8ac4ff;
      margin-top: 2px; min-height: 14px;
    }
    /* Card links section */
    .card-links {
      display: flex;
      gap: 6px;
      margin-top: 8px;
      padding-top: 10px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .card-link {
      flex: 1;
      text-align: center;
      padding: 6px 0;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 500;
      color: #7fb8f0;
      text-decoration: none;
      background: rgba(74,158,255,0.06);
      border: 1px solid rgba(74,158,255,0.1);
      transition: background 0.12s;
    }
    .card-link:hover { background: rgba(74,158,255,0.14); }
    .card-subtitle {
      font-style: italic;
      color: #9ca3af;
      font-size: 11px;
      margin-bottom: 8px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    /* ── Toolbar ── */
    #toolbar {
      position: fixed;
      bottom: 18px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 6px 10px;
      background: rgba(14, 14, 18, 0.82);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      box-shadow: 0 8px 28px rgba(0,0,0,0.45);
      z-index: 200;
      user-select: none;
    }
    .tb-group { display: flex; align-items: center; gap: 6px; padding: 0 8px; }
    #tb-count { font-size: 13px; color: #999; white-space: nowrap; }
    .tb-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.08); margin: 0 4px; }
    .tb-icon {
      width: 40px; height: 36px;
      border: none; background: transparent; border-radius: 8px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: #999; transition: background 0.12s, color 0.12s; padding: 0;
    }
    .tb-icon:hover { background: rgba(255,255,255,0.06); color: #e0e0e0; }
    .tb-icon.active { background: rgba(74,158,255,0.15); color: #4a9eff; }
    .tb-icon.on { color: #4a9eff; }
    .tb-icon svg { width: 20px; height: 20px; }
    #tb-clear {
      width: 24px; height: 24px; border: none; background: transparent;
      border-radius: 4px; cursor: pointer; color: #666; font-size: 16px;
      display: none; align-items: center; justify-content: center; padding: 0;
    }
    #tb-clear:hover { color: #fff; }
    #tb-clear.visible { display: flex; }

    /* ── Point size slider ── */
    .tb-slider-wrap {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 6px;
    }
    .tb-slider-wrap label {
      font-size: 10px;
      color: #888;
      white-space: nowrap;
    }
    .tb-slider-wrap input[type="range"] {
      width: 80px;
      height: 3px;
      -webkit-appearance: none;
      appearance: none;
      background: rgba(255,255,255,0.15);
      border-radius: 2px;
      outline: none;
      cursor: pointer;
    }
    .tb-slider-wrap input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 12px; height: 12px;
      border-radius: 50%;
      background: #7fb8f0;
      border: none;
      cursor: pointer;
    }
    .tb-slider-val {
      font-size: 10px;
      color: #aaa;
      min-width: 20px;
      text-align: right;
    }

    /* ── Side Panels ── */
    .side-panel {
      position: fixed; top: 0; right: 0;
      width: 320px; height: 100vh;
      background: rgba(14, 14, 18, 0.82);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border-left: 1px solid rgba(255,255,255,0.06);
      box-shadow: -10px 0 32px rgba(0,0,0,0.45);
      z-index: 150;
      overflow-y: auto; overflow-x: hidden;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.1) transparent;
      transform: translateX(100%);
      transition: transform 0.25s cubic-bezier(.4,0,.2,1);
      display: flex; flex-direction: column;
    }
    .side-panel::-webkit-scrollbar { width: 4px; }
    .side-panel::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    .side-panel.open { transform: translateX(0); }
    .panel-head {
      padding: 14px 16px 10px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0;
    }
    .panel-title { font-weight: 600; font-size: 13px; color: #e0e0e0; }
    .panel-close {
      width: 24px; height: 24px; border: none; background: transparent;
      color: #666; font-size: 14px; cursor: pointer; border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
    }
    .panel-close:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .panel-body { padding: 12px 16px; flex: 1; }
    .panel-body label { font-size: 11px; color: #999; display: block; margin-bottom: 4px; }
    .panel-body select, .panel-body input[type="text"] {
      width: 100%; padding: 6px 8px; border-radius: 6px;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.04); color: #e0e0e0;
      font-size: 12px; box-sizing: border-box;
    }
    /* Color panel legend */
    .panel-body select { margin-bottom: 12px; }
    .panel-body .search-row { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }
    .panel-body .search-btn {
      background: #4a9eff; border: none; color: #fff;
      padding: 6px 12px; border-radius: 6px; cursor: pointer;
      font-size: 12px; white-space: nowrap;
    }
    .panel-body .search-btn:hover { opacity: 0.9; }
    .panel-body .search-btn.clear {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1); color: #888;
    }
    .panel-body .partial-match {
      display: flex; align-items: center; gap: 4px;
      font-size: 11px; cursor: pointer; color: #888;
    }
    #panel-explore .panel-body {
      padding: 0;
