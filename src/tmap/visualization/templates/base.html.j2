{% block extra_elements %}{% endblock %}
  <!-- fflate for decompression -->
  <script src="https://cdn.jsdelivr.net/npm/fflate@0.8.2/umd/index.min.js"></script>
  <!-- SmilesDrawer for molecule rendering -->
  <script src="https://unpkg.com/smiles-drawer@2.2.1/dist/smiles-drawer.min.js"></script>

  <script type="module">
    const decode = (b64) => atob(b64);
    const mkModule = (code) =>
      URL.createObjectURL(new Blob([code], { type: 'application/javascript' }));

    const reglSource = decode("{{ runtime_regl }}");
    const pubSubSource = decode("{{ runtime_pubsub }}");
    const scatterSourceRaw = decode("{{ runtime_scatterplot }}");

    const reglModuleSource = `
const module = { exports: {} };
const exports = module.exports;
const globalThisRef = typeof globalThis !== 'undefined' ? globalThis : window;
${reglSource}
export default module.exports || globalThisRef.createREGL || createREGL;
`;
    const reglUrl = mkModule(reglModuleSource);
    const pubSubUrl = mkModule(pubSubSource);
    const scatterSource = scatterSourceRaw
      .replace(/from "regl"/g, 'from "' + reglUrl + '"')
      .replace(/from 'regl'/g, 'from "' + reglUrl + '"')
      .replace(/from "pub-sub-es"/g, 'from "' + pubSubUrl + '"')
      .replace(/from 'pub-sub-es'/g, 'from "' + pubSubUrl + '"');
    const scatterUrl = mkModule(scatterSource);

    const runtime = `
import createScatterplot from '${scatterUrl}';
import createREGL from '${reglUrl}';

const loading = document.getElementById('loading');
const progressFill = document.getElementById('progress-fill');
const progressText = document.getElementById('progress-text');

function updateProgress(percent, text) {
  progressFill.style.width = percent + '%';
  progressText.textContent = text;
}

// Decode gzip-compressed binary data using fflate
function decodeGzipBuffer(buffer, dtype) {
  const bytes = new Uint8Array(buffer);
  const decompressed = fflate.gunzipSync(bytes);
  // fflate may return a view with non-zero byteOffset; copy to aligned buffer
  const aligned = decompressed.slice().buffer;
  switch (dtype) {
    case 'uint16': return new Uint16Array(aligned);
    case 'uint32': return new Uint32Array(aligned);
    case 'float32': return new Float32Array(aligned);
    case 'int32': return new Int32Array(aligned);
    default: throw new Error('Unknown dtype: ' + dtype);
  }
}

// Decode gzip-compressed JSON string data
function decodeGzipBufferString(buffer) {
  const bytes = new Uint8Array(buffer);
  const decompressed = fflate.gunzipSync(bytes);
  const text = new TextDecoder().decode(decompressed);
  return JSON.parse(text);
}

function dequantizeCoords(quantized, bits = 16) {
  const n = quantized.length / 2;
  const maxVal = bits === 16 ? 65535 : 4294967295;
  const scale = 2.0 / maxVal;
  const x = new Float32Array(n);
  const y = new Float32Array(n);
  for (let i = 0; i < n; i++) {
    x[i] = quantized[i * 2] * scale - 1.0;
    y[i] = quantized[i * 2 + 1] * scale - 1.0;
  }
  return { x, y };
}

// ============================================
// Load Data (inline or fetch)
// ============================================

{% if inline_data %}
// --- Inline mode: data embedded as base64 ---
updateProgress(5, 'Decoding inline data...');
const metadata = {{ inline_metadata | safe }};
{% else %}
// --- Server mode: data fetched via HTTP ---
updateProgress(5, 'Fetching metadata...');
const metadata = await fetch('./metadata.json').then(r => r.json());
{% endif %}

const colormaps = metadata.colormaps || {};
const layoutOptions = metadata.layoutOptions || [];
const labelOptions = metadata.labelOptions || [];
const columnMeta = metadata.columns || {};
const nEdges = metadata.nEdges || 0;

{% if inline_data %}
updateProgress(10, 'Decoding coordinates...');
const coordsRaw = Uint8Array.from(atob("{{ inline_coords }}"), c => c.charCodeAt(0));
{% else %}
updateProgress(10, 'Fetching coordinates...');
const coordsRaw = new Uint8Array(await fetch('./coords.bin').then(r => r.arrayBuffer()));
{% endif %}
const coordDtype = metadata.coordDtype || 'uint16';
const coordBits = coordDtype === 'uint16' ? 16 : 32;
const quantizedCoords = decodeGzipBuffer(coordsRaw.buffer, coordDtype);
const { x, y } = dequantizeCoords(quantizedCoords, coordBits);
const n = x.length;
const N = n;

updateProgress(30, 'Preparing visualization...');
const hasEdges = nEdges > 0;
const parsedEdgeWidth = Number(metadata.edgeWidth);
const edgeWidth = Number.isFinite(parsedEdgeWidth) && parsedEdgeWidth > 0 ? parsedEdgeWidth : 2;
const edgeStrokeStyle = metadata.edgeStrokeStyle || 'rgba(0, 0, 0, 0.5)';

updateProgress(40, 'Loading columns...');

// Load initial color layout column eagerly, others lazily
const columns = {};
const columnNames = Object.keys(columnMeta);
const initialColor = layoutOptions[0] || '';

{% if inline_data %}
// Inline column blobs keyed by column name
const _inlineBlobs = {
  {% for name, b64 in inline_columns.items() %}
  "{{ name }}": "{{ b64 }}",
  {% endfor %}
};
{% endif %}

// Decode a column from binary data (buffer)
function decodeColumnBuffer(name, buffer) {
  const meta = columnMeta[name];
  if (!meta) return null;
  if (meta.dtype === 'string') {
    const values = decodeGzipBufferString(buffer);
    columns[name] = { values, dtype: 'string', role: meta.role, colormap: meta.colormap };
  } else if (meta.dictionary) {
    const decoded = decodeGzipBuffer(buffer, meta.dtype);
    columns[name] = {
      values: Array.from(decoded).map(i => meta.dictionary[i]),
      dtype: 'categorical', role: meta.role, colormap: meta.colormap,
    };
  } else {
    const decoded = decodeGzipBuffer(buffer, meta.dtype);
    columns[name] = {
      values: decoded,
      dtype: meta.dtype === 'float32' ? 'continuous' : meta.dtype,
      role: meta.role, colormap: meta.colormap,
    };
  }
  return columns[name];
}

// Fetch/decode a column by name
async function fetchColumn(name) {
  if (columns[name]) return columns[name];
  const meta = columnMeta[name];
  if (!meta) return null;

{% if inline_data %}
  const b64 = _inlineBlobs[name];
  if (!b64) return null;
  const raw = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
  return decodeColumnBuffer(name, raw.buffer);
{% else %}
  const fileKey = meta.file || name;
  const resp = await fetch('./col_' + encodeURIComponent(fileKey) + '.bin');
  if (!resp.ok) return null;
  const buffer = await resp.arrayBuffer();
  return decodeColumnBuffer(name, buffer);
{% endif %}
}

// Critical path: only initial color + protein ID (for card title / tooltip label)
const criticalFetches = [];
if (initialColor) criticalFetches.push(fetchColumn(initialColor));
if (metadata.proteinColumn && columnMeta[metadata.proteinColumn]) {
  criticalFetches.push(fetchColumn(metadata.proteinColumn));
}
if (metadata.smilesColumn && columnMeta[metadata.smilesColumn]) {
  criticalFetches.push(fetchColumn(metadata.smilesColumn));
}
await Promise.all(criticalFetches);

// Deferred: load remaining columns in background after scatterplot renders.
// Tooltips and cards degrade gracefully (skip unloaded columns).
const _deferredNames = [];
for (const name of labelOptions) { if (!columns[name]) _deferredNames.push(name); }
for (const special of [metadata.imagesColumn, metadata.structures3dColumn]) {
  if (special && columnMeta[special] && !columns[special]) _deferredNames.push(special);
}
(async () => {
  // Batch fetches (4 concurrent) to avoid saturating the connection
  for (let i = 0; i < _deferredNames.length; i += 4) {
    await Promise.all(_deferredNames.slice(i, i + 4).map(fetchColumn));
  }
})();

updateProgress(80, 'Initializing visualization...');

// ============================================
// Visualization Setup
// ============================================

const canvas = document.getElementById('canvas');
const colorSelect = document.getElementById('color-select-panel');
const tooltip = document.getElementById('tooltip');
const tooltipLabel = document.getElementById('tooltip-label');
const tooltipContent = document.getElementById('tooltip-content');
const legendTitle = document.getElementById('legend-title');
const legendContent = document.getElementById('legend-content');

function createLinearScale(initialDomain, initialRange) {
  let d0 = initialDomain[0], d1 = initialDomain[1];
  let r0 = initialRange[0], r1 = initialRange[1];
  const scale = (value) => {
    const denom = d1 - d0;
    if (denom === 0) return r0;
    return r0 + ((value - d0) / denom) * (r1 - r0);
  };
  scale.domain = (nd) => { if (nd === undefined) return [d0,d1]; d0=nd[0]; d1=nd[1]; return scale; };
  scale.range = (nr) => { if (nr === undefined) return [r0,r1]; r0=nr[0]; r1=nr[1]; return scale; };
  return scale;
}

const edgeXScale = createLinearScale([-1, 1], [0, canvas.clientWidth || window.innerWidth]);
const edgeYScale = createLinearScale([-1, 1], [canvas.clientHeight || window.innerHeight, 0]);

const fallbackPointColor = metadata.pointColor || '#4a9eff';

const scatterplot = createScatterplot({
  canvas,
  width: canvas.clientWidth || window.innerWidth,
  height: canvas.clientHeight || window.innerHeight,
  pointSize: metadata.pointSize || 4,
  pointSizeSelected: 8,
  opacity: metadata.opacity ?? 0.85,
  opacityInactiveScale: 0.5,
  backgroundColor: metadata.backgroundColor || [0, 0, 0, 1],
  pointColor: fallbackPointColor,
  pointOutlineWidth: 2,
  colorBy: null,
  lassoInitiator: false,
  xScale: edgeXScale,
  yScale: edgeYScale,
  performanceMode: N > 500000,
});

const zeroArray = new Float32Array(n);
const NAN_FALLBACK_COLOR = '#000000';

// === WebGL Edge Rendering ===
// Edges rendered via regl on a separate WebGL canvas (GPU-accelerated).
// For N > 1M, edges default to OFF and load lazily on first toggle.
let edgeNeedsRedraw = false;
let edgesVisible = hasEdges && N <= 1_000_000;
let edgesLoaded = false;
let edgeRegl = null;
let drawEdgesCmd = null;
let edgeCanvas = null;

function parseEdgeColor(str) {
  const m = str.match(/rgba?\\(\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*(?:,\\s*([\\d.]+))?\\s*\\)/);
  if (m) return [+m[1]/255, +m[2]/255, +m[3]/255, m[4] !== undefined ? +m[4] : 1];
  return [0, 0, 0, 0.5];
}
let edgeColor = parseEdgeColor(edgeStrokeStyle);

const edgeToggle = document.getElementById('edge-toggle');
const tbEdges = document.getElementById('tb-edges');
if (tbEdges && edgesVisible) tbEdges.classList.add('on');

function resizeEdgeCanvas() {
  if (!edgeCanvas) return;
  const dpr = window.devicePixelRatio || 1;
  edgeCanvas.width = window.innerWidth * dpr;
  edgeCanvas.height = window.innerHeight * dpr;
  if (edgeRegl) edgeRegl.poll();
  edgeNeedsRedraw = true;
}

if (hasEdges) {
  canvas.style.position = 'fixed';
  canvas.style.top = '0';
  canvas.style.left = '0';
  canvas.style.zIndex = '2';

  edgeCanvas = document.createElement('canvas');
  edgeCanvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:1;';
  canvas.parentNode.insertBefore(edgeCanvas, canvas);
  resizeEdgeCanvas();
}

async function loadEdges() {
  if (edgesLoaded || !hasEdges) return;

{% if inline_data %}
  const edgeRaw = Uint8Array.from(atob("{{ inline_edges }}"), c => c.charCodeAt(0));
  const buf = edgeRaw.buffer;
{% else %}
  const buf = await fetch('./edges.bin').then(r => r.arrayBuffer());
{% endif %}
  const raw = decodeGzipBuffer(buf, 'uint32');
  const eS = raw.subarray(0, nEdges);
  const eT = raw.subarray(nEdges, 2 * nEdges);

  // Interleaved position buffer from point coordinates
  const positions = new Float32Array(n * 2);
  for (let i = 0; i < n; i++) {
    positions[i * 2] = x[i];
    positions[i * 2 + 1] = y[i];
  }

  // Element index buffer: pairs of vertex indices per edge
  const elements = new Uint32Array(nEdges * 2);
  for (let i = 0; i < nEdges; i++) {
    elements[i * 2] = eS[i];
    elements[i * 2 + 1] = eT[i];
  }

  edgeRegl = createREGL({
    canvas: edgeCanvas,
    extensions: ['OES_element_index_uint'],
    attributes: { alpha: true, premultipliedAlpha: false, antialias: true },
  });

  const vertSrc = 'precision highp float; attribute vec2 position; uniform vec2 u_scale; uniform vec2 u_offset; void main() { gl_Position = vec4(position * u_scale + u_offset, 0.0, 1.0); }';
  const fragSrc = 'precision mediump float; uniform vec4 u_color; void main() { gl_FragColor = u_color; }';

  drawEdgesCmd = edgeRegl({
    vert: vertSrc,
    frag: fragSrc,
    attributes: {
      position: { buffer: edgeRegl.buffer(positions), size: 2 },
    },
    elements: edgeRegl.elements({ data: elements, primitive: 'lines', type: 'uint32' }),
    uniforms: {
      u_scale: edgeRegl.prop('scale'),
      u_offset: edgeRegl.prop('offset'),
      u_color: edgeRegl.prop('color'),
    },
    blend: {
      enable: true,
      func: { srcRGB: 'src alpha', srcAlpha: 1, dstRGB: 'one minus src alpha', dstAlpha: 1 },
    },
    depth: { enable: false },
  });

  edgesLoaded = true;
  edgeNeedsRedraw = true;
}

function renderEdges() {
  if (!edgesLoaded || !edgesVisible || !edgeRegl) return;
  edgeRegl.poll();
  edgeRegl.clear({ color: [0, 0, 0, 0] });

  // Derive data-to-clip-space transform from scatterplot's live scales
  const xd = edgeXScale.domain();
  const yd = edgeYScale.domain();
  const xRange = xd[1] - xd[0] || 1;
  const yRange = yd[1] - yd[0] || 1;

  drawEdgesCmd({
    scale: [2 / xRange, 2 / yRange],
    offset: [-(xd[1] + xd[0]) / xRange, -(yd[1] + yd[0]) / yRange],
    color: edgeColor,
  });
  edgeNeedsRedraw = false;
}

const redrawEdges = renderEdges;

if (hasEdges) {
  scatterplot.subscribe('drawing', (event) => {
    if (!edgesVisible || !edgesLoaded) return;
    if (edgeNeedsRedraw || (event && event.isViewChanged)) renderEdges();
  });

  // Edge resize is handled by the unified resize handler below.

  async function toggleEdges() {
    edgesVisible = !edgesVisible;
    if (tbEdges) tbEdges.classList.toggle('on', edgesVisible);
    if (edgesVisible && !edgesLoaded) {
      try { await loadEdges(); } catch (err) {
        console.error('Failed to load edges:', err);
        edgesVisible = false;
        if (tbEdges) tbEdges.classList.remove('on');
        return;
      }
    }
    if (edgesVisible) { edgeNeedsRedraw = true; renderEdges(); }
    else if (edgeRegl) { edgeRegl.poll(); edgeRegl.clear({ color: [0, 0, 0, 0] }); }
  }
  if (tbEdges) tbEdges.addEventListener('click', toggleEdges);

  // For small datasets (<=1M), load edges eagerly during startup
  if (edgesVisible) await loadEdges();
} else {
  if (tbEdges) tbEdges.style.display = 'none';
}

// Color mapping
function buildContinuousMapping(rawValues, baseCmap) {
  const nums = new Float64Array(rawValues.length);
  const missing = new Array(rawValues.length);
  let min = Infinity, max = -Infinity, hasNaN = false;

  for (let i = 0; i < rawValues.length; i++) {
    const raw = rawValues[i];
    const v = Number(raw);
    nums[i] = v;
    const isMissing = raw === null || raw === undefined || !Number.isFinite(v);
    missing[i] = isMissing;
    if (isMissing) { hasNaN = true; continue; }
    if (v < min) min = v;
    if (v > max) max = v;
  }

  if (min === Infinity) { min = 0; max = 0; }
  const range = max === min ? 1 : max - min;
  const w = new Float32Array(rawValues.length);

  if (!hasNaN) {
    for (let i = 0; i < rawValues.length; i++) w[i] = (nums[i] - min) / range;
    return { cmap: baseCmap, w, min, max, hasNaN: false };
  }

  const baseCount = Math.max(1, baseCmap.length);
  const offset = 1 / baseCount;
  const scale = baseCount > 1 ? (baseCount - 1) / baseCount : 0;
  for (let i = 0; i < rawValues.length; i++) {
    w[i] = missing[i] ? 0 : ((nums[i] - min) / range) * scale + offset;
  }
  return { cmap: [NAN_FALLBACK_COLOR, ...baseCmap], w, min, max, hasNaN: true };
}

async function applyColor(columnName) {
  const col = await fetchColumn(columnName);
  if (!col) {
    scatterplot.set({ colorBy: null, pointColor: fallbackPointColor });
    edgeNeedsRedraw = true;
    scatterplot.draw({ x, y }).then(() => { redrawEdges(); });
    updateLegend('', null);
    return;
  }

  const cmap = (col.colormap && colormaps[col.colormap]) || [fallbackPointColor];

  if (col.dtype === 'categorical') {
    // Collect unique values
    const uniqueSet = new Set();
    const values = col.values;
    for (let i = 0; i < n; i++) uniqueSet.add(values[i]);
    const unique = [...uniqueSet];
    // Sort numerically if all values are numbers
    const allNum = unique.every(v => !isNaN(Number(v)));
    if (allNum) unique.sort((a, b) => Number(a) - Number(b));
    const mapping = new Map();
    unique.forEach((v, i) => mapping.set(v, i));
    const z = new Float32Array(n);
    for (let i = 0; i < n; i++) z[i] = mapping.get(values[i]);
    col._sortedMapping = mapping;
    edgeNeedsRedraw = true;
    scatterplot.set({ colorBy: 'valueA', pointColor: cmap });
    scatterplot.draw({ x, y, z, w: zeroArray }).then(() => { redrawEdges(); });
  } else {
    const mapping = buildContinuousMapping(col.values, cmap);
    edgeNeedsRedraw = true;
    scatterplot.set({ colorBy: 'valueB', pointColor: mapping.cmap });
    scatterplot.draw({ x, y, z: zeroArray, w: mapping.w }).then(() => { redrawEdges(); });
  }
  updateLegend(columnName, col);
}

function escapeHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function formatValue(val) {
  if (typeof val === 'number') {
    if (Number.isInteger(val)) return val.toLocaleString();
    return parseFloat(val.toFixed(3)).toString();
  }
  return escapeHtml(val);
}

function buildGradient(colors) {
  if (!colors || colors.length === 0) return '#000000';
  const steps = Math.min(12, colors.length);
  if (steps === 1) return colors[0];
  const stops = [];
  for (let i = 0; i < steps; i++) {
    const t = i / (steps - 1);
    const idx = Math.round((colors.length - 1) * t);
    stops.push(colors[idx] + ' ' + Math.round(t * 100) + '%');
  }
  return 'linear-gradient(90deg, ' + stops.join(', ') + ')';
}

function updateLegend(columnName, col) {
  if (!col || col.role === 'label') {
    legendTitle.textContent = '';
    legendContent.innerHTML = '';
    return;
  }

  const cmap = (col.colormap && colormaps[col.colormap]) || [fallbackPointColor];
  legendTitle.textContent = columnName;

  if (col.dtype === 'categorical') {
    // Use the sorted mapping built by applyColor
    const sortedItems = col._sortedMapping ? [...col._sortedMapping.keys()] : [];
    let html = '';
    for (let i = 0; i < sortedItems.length; i++) {
      html += '<div class="legend-item"><span class="legend-swatch" style="background:' +
        cmap[i % cmap.length] + '"></span><span>' + escapeHtml(sortedItems[i]) + '</span></div>';
    }
    legendContent.innerHTML = html;
  } else {
    const mapping = buildContinuousMapping(col.values, cmap);
    let legendHtml =
      '<div class="legend-gradient" style="background:' + buildGradient(cmap) + '"></div>' +
      '<div class="legend-range"><span>' + formatValue(mapping.min) + '</span><span>' +
      formatValue(mapping.max) + '</span></div>';
    if (mapping.hasNaN) {
      legendHtml +=
        '<div class="legend-item"><span class="legend-swatch" style="background:' +
        NAN_FALLBACK_COLOR + '"></span><span>NaN</span></div>';
    }
    legendContent.innerHTML = legendHtml;
  }
}

// Tooltip
let mouseX = 0, mouseY = 0;
canvas.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

function showTooltip(idx) {
  let label = 'Point ' + idx;
  for (const name of labelOptions) {
    const col = columns[name];
    if (col && col.values[idx] !== undefined) { label = col.values[idx]; break; }
  }
  tooltipLabel.textContent = label;

  let html = '';
  for (const name of labelOptions) {
    const col = columns[name];
    if (!col) continue;
    const val = col.values[idx];
    html += '<div class="row"><span class="key">' + escapeHtml(name) + '</span><span class="value">' + formatValue(val) + '</span></div>';
  }
  tooltipContent.innerHTML = html;

  tooltip.classList.add('visible');
  const rect = tooltip.getBoundingClientRect();
  let left = mouseX + 12;
  let top = mouseY + 12;
  if (left + rect.width > window.innerWidth - 8) left = mouseX - rect.width - 12;
  if (top + rect.height > window.innerHeight - 8) top = mouseY - rect.height - 12;
  tooltip.style.left = left + 'px';
  tooltip.style.top = top + 'px';
}

function hideTooltip() { tooltip.classList.remove('visible'); }

scatterplot.subscribe('pointover', (idx) => showTooltip(idx));
scatterplot.subscribe('pointout', hideTooltip);

// Resize — unified handler for scatterplot, edges, and UI.
// Use window.innerWidth/Height because scatterplot.set() overwrites
// the canvas CSS to fixed pixels, so getBoundingClientRect() would
// return the stale old size.  set() internally updates canvas pixel
// dimensions, scale ranges, and queues a redraw; the 'drawing' event
// then triggers edge redraw via edgeNeedsRedraw.
window.addEventListener('resize', () => {
  scatterplot.set({ width: window.innerWidth, height: window.innerHeight });
  if (hasEdges) {
    resizeEdgeCanvas();
  }
  cardBodyMaxHeight = clampCardBodyHeight(cardBodyMaxHeight);
  applyCardSize();
});

// Color selector
for (const name of layoutOptions) {
  const meta = columnMeta[name];
  if (!meta) continue;
  const opt = document.createElement('option');
  opt.value = name;
  const dtype = meta.dictionary ? 'categorical' : (meta.dtype === 'float32' ? 'continuous' : meta.dtype);
  opt.textContent = name + ' (' + dtype + ')';
  colorSelect.appendChild(opt);
}
if (initialColor) colorSelect.value = initialColor;
colorSelect.addEventListener('change', (e) => applyColor(e.target.value));

// Initial render
updateProgress(95, 'Rendering...');
await applyColor(initialColor || '');
redrawEdges();

updateProgress(100, 'Complete!');
setTimeout(() => { loading.classList.add('hidden'); }, 200);

console.log('Loaded ' + n.toLocaleString() + ' points (server mode)');

// ============================================
// Card Stack System (single-click pinned cards)
// ============================================

const cardStack = document.getElementById('card-stack');
const CARD_WIDTH_STORAGE_KEY = 'tmap.card.width';
const CARD_BODY_HEIGHT_STORAGE_KEY = 'tmap.card.bodyMaxHeight';
const CARD_WIDTH_DEFAULT = 320;
const CARD_WIDTH_MIN = 280;
const CARD_WIDTH_MAX = 520;
const CARD_BODY_HEIGHT_DEFAULT = 420;
const CARD_BODY_HEIGHT_MIN = 220;
const pinnedCards = []; // Array of point indices
let currentCardIndex = 0;

const MAX_CARDS = 50;

function clampCardWidth(width) {
  const w = Number(width);
  if (!Number.isFinite(w)) return CARD_WIDTH_DEFAULT;
  return Math.max(CARD_WIDTH_MIN, Math.min(CARD_WIDTH_MAX, Math.round(w)));
}

function cardBodyHeightUpperBound() {
  return Math.max(CARD_BODY_HEIGHT_MIN, window.innerHeight - 120);
}

function clampCardBodyHeight(height) {
  const h = Number(height);
  if (!Number.isFinite(h)) return CARD_BODY_HEIGHT_DEFAULT;
  return Math.max(CARD_BODY_HEIGHT_MIN, Math.min(cardBodyHeightUpperBound(), Math.round(h)));
}

function loadStoredCardDimension(key, clampFn) {
  try {
    const raw = window.localStorage.getItem(key);
    if (raw === null || raw === '') return null;
    return clampFn(raw);
  } catch (e) {
    return null;
  }
}

const storedCardWidth = loadStoredCardDimension(CARD_WIDTH_STORAGE_KEY, clampCardWidth);
const storedCardBodyHeight = loadStoredCardDimension(
  CARD_BODY_HEIGHT_STORAGE_KEY,
  clampCardBodyHeight,
);
let cardWidth = storedCardWidth === null ? CARD_WIDTH_DEFAULT : storedCardWidth;
let cardBodyMaxHeight = (
  storedCardBodyHeight === null ? CARD_BODY_HEIGHT_DEFAULT : storedCardBodyHeight
);
let hasCardSizeOverride = storedCardWidth !== null || storedCardBodyHeight !== null;

function applyCardSize() {
  cardBodyMaxHeight = clampCardBodyHeight(cardBodyMaxHeight);
  cardStack.style.setProperty('--card-width', cardWidth + 'px');
  cardStack.style.setProperty('--card-body-max-height', cardBodyMaxHeight + 'px');
  const card = cardStack.querySelector('.card');
  const cardBody = cardStack.querySelector('.card-body');
  if (!card || !cardBody) return;
  if (hasCardSizeOverride) {
    card.style.setProperty('width', cardWidth + 'px', 'important');
    cardBody.style.setProperty('max-height', cardBodyMaxHeight + 'px', 'important');
  } else {
    card.style.removeProperty('width');
    cardBody.style.removeProperty('max-height');
  }
}

function setCardSize(width, bodyHeight, persist = true) {
  cardWidth = clampCardWidth(width);
  cardBodyMaxHeight = clampCardBodyHeight(bodyHeight);
  hasCardSizeOverride = true;
  applyCardSize();
  if (!persist) return;
  try {
    window.localStorage.setItem(CARD_WIDTH_STORAGE_KEY, String(cardWidth));
    window.localStorage.setItem(CARD_BODY_HEIGHT_STORAGE_KEY, String(cardBodyMaxHeight));
  } catch (e) {
    // no-op: storage may be unavailable
  }
}

applyCardSize();

function startCardResize(e) {
  if (e.pointerType === 'mouse' && e.button !== 0) return;
  e.preventDefault();
  e.stopPropagation();
  const handle = e.currentTarget;
  const pointerId = e.pointerId;
  const startX = e.clientX;
  const startY = e.clientY;
  const startWidth = cardWidth;
  const startBodyHeight = cardBodyMaxHeight;
  document.body.classList.add('card-resizing');

  if (handle && handle.setPointerCapture) {
    try { handle.setPointerCapture(pointerId); } catch (err) {}
  }

  function onMove(ev) {
    if (pointerId !== undefined && ev.pointerId !== pointerId) return;
    const deltaX = ev.clientX - startX;
    const deltaY = ev.clientY - startY;
    setCardSize(startWidth + deltaX, startBodyHeight + deltaY, false);
  }

  function onUp(ev) {
    if (pointerId !== undefined && ev.pointerId !== pointerId) return;
    handle?.removeEventListener('pointermove', onMove);
    handle?.removeEventListener('pointerup', onUp);
    handle?.removeEventListener('pointercancel', onUp);
    if (handle && handle.releasePointerCapture) {
      try { handle.releasePointerCapture(pointerId); } catch (err) {}
    }
    document.body.classList.remove('card-resizing');
    setCardSize(cardWidth, cardBodyMaxHeight, true);
  }

  handle?.addEventListener('pointermove', onMove);
  handle?.addEventListener('pointerup', onUp);
  handle?.addEventListener('pointercancel', onUp);
}

function getLabel(idx) {
  for (const name of labelOptions) {
    const col = columns[name];
    if (col && col.values[idx] !== undefined) {
      return col.values[idx];
    }
  }
  return 'Point ' + idx;
}

let hoveredPointIndex = -1;
let cardMinimized = false;
scatterplot.subscribe('pointover', (idx) => { hoveredPointIndex = idx; });
scatterplot.subscribe('pointout', () => { hoveredPointIndex = -1; });

// Drag detection - only select on click, not drag
let mouseDownPos = null;
const DRAG_THRESHOLD = 5;

canvas.addEventListener('mousedown', (e) => {
  mouseDownPos = { x: e.clientX, y: e.clientY };
});

canvas.addEventListener('mouseup', (e) => {
  if (!mouseDownPos) return;

  const dx = e.clientX - mouseDownPos.x;
  const dy = e.clientY - mouseDownPos.y;
  const distance = Math.sqrt(dx * dx + dy * dy);
  mouseDownPos = null;

  if (distance > DRAG_THRESHOLD) return;
  if (e.shiftKey || e.ctrlKey || e.metaKey) return;
  if (hoveredPointIndex < 0) return;

  const idx = hoveredPointIndex;
  const existingIndex = pinnedCards.indexOf(idx);

  if (existingIndex >= 0) {
    currentCardIndex = existingIndex;
  } else {
    if (pinnedCards.length >= MAX_CARDS) {
      pinnedCards.shift();
    }
    pinnedCards.push(idx);
    currentCardIndex = pinnedCards.length - 1;
  }
  renderCardStack();
});

function truncateString(str, maxLen) {
  str = escapeHtml(str);
  if (!str || str.length <= maxLen) return str;
  return str.substring(0, maxLen - 3) + '...';
}

function renderCardStack() {
  if (pinnedCards.length === 0) {
    cardStack.classList.add('hidden');
    cardStack.innerHTML = '';
    return;
  }

  cardStack.classList.remove('hidden');
  const idx = pinnedCards[currentCardIndex];
  const cardConfig = metadata.card || null;

  // Resolve a card config value: template ("{col}") or plain column name
  function resolveCardField(template, idx, fallback) {
    if (!template) return fallback;
    if (template.includes('{')) {
      return template.replace(/\{([^}]+)\}/g, (match, colName) => {
        const c = columns[colName];
        return c ? String(c.values[idx]) : match;
      });
    }
    const col = columns[template];
    return col ? String(col.values[idx]) : fallback;
  }

  const cardTitle = resolveCardField(cardConfig && cardConfig.titleColumn, idx, getLabel(idx));

  // Find SMILES column (if any)
  const smilesColName = metadata.smilesColumn;
  const smilesCol = smilesColName ? columns[smilesColName] : null;
  const smilesValue = smilesCol ? smilesCol.values[idx] : null;

  let html = '<div class="card' + (cardMinimized ? ' minimized' : '') + '">';

  // Header with navigation
  html += '<div class="card-header">';
  html += '<div class="card-nav">';
  html += '<button id="card-prev" ' + (currentCardIndex <= 0 ? 'disabled' : '') + '>&larr;</button>';
  html += '<span>' + (currentCardIndex + 1) + ' of ' + pinnedCards.length + '</span>';
  html += '<button id="card-next" ' + (currentCardIndex >= pinnedCards.length - 1 ? 'disabled' : '') + '>&rarr;</button>';
  html += '</div>';
  html += '<div>';
  html += '<button class="card-minimize" id="card-minimize" title="' + (cardMinimized ? 'Expand' : 'Minimize') + '">' + (cardMinimized ? '&#9650;' : '&#9660;') + '</button>';
  html += '<button class="card-close" id="card-close" title="Close">&times;</button>';
  html += '</div>';
  html += '</div>';

  // Card body
  html += '<div class="card-body">';
  html += '<div class="card-label">' + truncateString(cardTitle, 40) + '</div>';

  // Subtitle (from card config)
  {
    const subtitle = resolveCardField(cardConfig && cardConfig.subtitleColumn, idx, null);
    if (subtitle) {
      html += '<div class="card-subtitle">' + truncateString(subtitle, 50) + '</div>';
    }
  }

  // Links (from card config) — placed prominently before structure/fields
  if (cardConfig && cardConfig.links && cardConfig.links.length > 0) {
    html += '<div class="card-links">';
    for (const link of cardConfig.links) {
      let url = link.url;
      url = url.replace(/\{([^}]+)\}/g, (match, colName) => {
        const c = columns[colName];
        return c ? encodeURI(String(c.values[idx])) : match;
      });
      html += '<a class="card-link" href="' + url + '" target="_blank" rel="noopener">' + escapeHtml(link.label) + '</a>';
    }
    html += '</div>';
  }

  // Structure container placeholder (only if SMILES or protein data exists)
  if (metadata.smilesColumn || metadata.proteinColumn || metadata.structures3dColumn) {
    html += '<div class="card-structure-container hidden" id="card-structure"></div>';
  }
  // Image container placeholder (only if images data exists)
  if (metadata.imagesColumn) {
    html += '<div class="card-image-container hidden" id="card-image"></div>';
  }

  // SMILES row with copy button
  if (smilesValue && typeof smilesValue === 'string') {
    html += '<div class="card-copy-row">';
    html += '<span class="key">SMILES</span>';
    html += '<span class="value">' + truncateString(smilesValue, 25) + '</span>';
    html += '<button class="card-copy-btn" id="copy-smiles" data-value="' + smilesValue.replace(/"/g, '&quot;') + '">Copy</button>';
    html += '</div>';
  }

  // Determine which fields to show
  const fieldList = (cardConfig && cardConfig.fields) ? cardConfig.fields : labelOptions;
  const skipColumns = new Set();
  if (smilesColName) skipColumns.add(smilesColName);
  if (cardConfig && cardConfig.titleColumn) skipColumns.add(cardConfig.titleColumn);
  if (cardConfig && cardConfig.subtitleColumn) skipColumns.add(cardConfig.subtitleColumn);

  for (const name of fieldList) {
    if (skipColumns.has(name)) continue;
    const col = columns[name];
    if (!col) continue;
    const val = col.values[idx];
    const colUi = (columnMeta[name] && columnMeta[name].ui) || {};
    const displayName = colUi.displayName || name;
    const displayVal = truncateString(formatValue(val), 30);
    const colRole = (columnMeta[name] && columnMeta[name].role) || '';
    const isLayoutCol = colRole.indexOf('layout') !== -1;
    const isCopyable = colUi.copyable === true || (!isLayoutCol && typeof val === 'string' && val.length > 0 && colUi.copyable !== false);

    if (isCopyable && typeof val === 'string' && val.length > 0) {
      html += '<div class="card-copy-row">';
      html += '<span class="key">' + escapeHtml(displayName) + '</span>';
      html += '<span class="value">' + displayVal + '</span>';
      html += '<button class="card-copy-btn" data-value="' + String(val).replace(/"/g, '&quot;') + '">Copy</button>';
      html += '</div>';
    } else {
      html += '<div class="card-row">';
      html += '<span class="key">' + escapeHtml(displayName) + '</span>';
      html += '<span class="value">' + displayVal + '</span>';
      html += '</div>';
    }
  }

  html += '</div>'; // close card-body
  html += '</div>'; // close card
  html += '<div class="card-resize-handle" id="card-resize-handle" title="Resize panel"></div>';
  cardStack.innerHTML = html;
  applyCardSize();

  // Attach event listeners
  document.getElementById('card-prev')?.addEventListener('click', () => {
    if (currentCardIndex > 0) { currentCardIndex--; renderCardStack(); }
  });
  document.getElementById('card-next')?.addEventListener('click', () => {
    if (currentCardIndex < pinnedCards.length - 1) { currentCardIndex++; renderCardStack(); }
  });
  document.getElementById('card-minimize')?.addEventListener('click', () => {
    cardMinimized = !cardMinimized;
    renderCardStack();
  });
  document.getElementById('card-close')?.addEventListener('click', () => {
    pinnedCards.splice(currentCardIndex, 1);
    if (currentCardIndex >= pinnedCards.length) currentCardIndex = Math.max(0, pinnedCards.length - 1);
    renderCardStack();
  });
  document.getElementById('card-resize-handle')?.addEventListener('pointerdown', startCardResize);

  // Copy buttons
  cardStack.querySelectorAll('.card-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const value = btn.dataset.value;
      try {
        await navigator.clipboard.writeText(value);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      } catch (err) {
        console.error('Copy failed:', err);
        btn.textContent = 'Failed';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      }
    });
  });

  // Trigger custom event for SMILES template extension
  cardStack.dispatchEvent(new CustomEvent('cardrendered', { detail: { idx, smilesValue } }));
}

// ============================================
// Export Panel System (multi-select)
// ============================================

const exportPanel = document.getElementById('export-panel');
const exportTitle = document.getElementById('export-title');
const exportColumns = document.getElementById('export-columns');
const exportCsvBtn = document.getElementById('export-csv');
const exportTsvBtn = document.getElementById('export-tsv');
const exportClearBtn = document.getElementById('export-clear');
const exportCloseBtn = document.getElementById('export-close');

let selectedIndices = [];

// Build column checkboxes (fetch all label columns first)
async function buildExportColumns() {
  let html = '';
  for (const name of labelOptions) {
    const col = await fetchColumn(name);
    if (!col) continue;
    html += '<label><input type="checkbox" value="' + escapeHtml(name) + '" checked> ' + escapeHtml(name) + '</label>';
  }
  exportColumns.innerHTML = html;
}
buildExportColumns();

function showExportPanel(indices) {
  selectedIndices = indices;
  exportTitle.textContent = indices.length.toLocaleString() + ' points selected';
  exportPanel.classList.remove('hidden');
}

function hideExportPanel() {
  selectedIndices = [];
  exportPanel.classList.add('hidden');
}

scatterplot.subscribe('select', (selection) => {
  const indices = selection.points || selection;
  if (Array.isArray(indices) && indices.length > 1) {
    showExportPanel(indices);
  } else {
    hideExportPanel();
  }
});

function getSelectedColumns() {
  const checked = [];
  exportColumns.querySelectorAll('input[type="checkbox"]:checked').forEach((cb) => {
    checked.push(cb.value);
  });
  return checked;
}

async function exportData(separator, extension) {
  const colNames = getSelectedColumns();
  if (colNames.length === 0 || selectedIndices.length === 0) return;

  // Ensure all selected columns are fetched
  for (const name of colNames) {
    await fetchColumn(name);
  }

  const rows = [colNames.join(separator)];

  for (const idx of selectedIndices) {
    const rowValues = colNames.map((name) => {
      const col = columns[name];
      if (!col) return '';
      const val = col.values[idx];
      let strVal = val == null ? '' : String(val);
      if (strVal.includes(separator) || strVal.includes('"') || strVal.includes('\\n')) {
        strVal = '"' + strVal.replace(/"/g, '""') + '"';
      }
      return strVal;
    });
    rows.push(rowValues.join(separator));
  }

  const content = rows.join('\\n');
  const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
  const url = URL.createObjectURL(blob);

  const a = document.createElement('a');
  a.href = url;
  a.download = 'tmap_export_' + selectedIndices.length + '_points.' + extension;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

