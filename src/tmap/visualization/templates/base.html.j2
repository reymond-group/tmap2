// ============================================
// SMILES Rendering via SmilesDrawer
// ============================================

const smilesColumn = metadata.smilesColumn;
const tooltipStructure = document.getElementById('tooltip-structure');

if (smilesColumn && columnMeta[smilesColumn]) {
  // Create SVG element inside the tooltip structure container
  const structureSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  structureSvg.id = 'structure-svg';
  tooltipStructure.appendChild(structureSvg);

  const g = typeof window !== 'undefined' ? window : globalThis;
  const SmiDrawerCtor = g.SmiDrawer;
  const SmilesDrawerLib = g.SmilesDrawer;

  const drawerOptions = { width: 240, height: 200, bondThickness: 1.0, compactDrawing: false };

  let drawer = null;
  let drawSmiles = null;

  if (SmiDrawerCtor) {
    drawer = new SmiDrawerCtor(drawerOptions);
    drawSmiles = (smiles) => drawer.draw(smiles, '#structure-svg', 'light');
  } else if (SmilesDrawerLib && SmilesDrawerLib.Drawer && SmilesDrawerLib.parse) {
    drawer = new SmilesDrawerLib.Drawer(drawerOptions);
    drawSmiles = (smiles) =>
      SmilesDrawerLib.parse(
        smiles,
        (tree) => drawer.draw(tree, 'structure-svg', 'light', false),
        (err) => {
          console.warn('Failed to parse SMILES:', smiles, err);
          tooltipStructure.classList.add('hidden');
        },
      );
  }

  if (!drawSmiles) {
    console.error('SmilesDrawer not loaded! Tried SmiDrawer and SmilesDrawer');
  } else {
    const originalShowTooltip = showTooltip;
    showTooltip = function(idx) {
      originalShowTooltip(idx);

      const smilesCol = columns[smilesColumn];
      if (!smilesCol) { tooltipStructure.classList.add('hidden'); return; }

      const smiles = smilesCol.values[idx];
      if (!smiles || typeof smiles !== 'string' || !smiles.trim()) {
        tooltipStructure.classList.add('hidden');
        return;
      }

      tooltipStructure.classList.remove('hidden');
      structureSvg.innerHTML = '';

      try {
        drawSmiles(smiles);
      } catch (err) {
        console.warn('Failed to render SMILES:', smiles, err);
        tooltipStructure.classList.add('hidden');
      }
    };

    const originalHideTooltip = hideTooltip;
    hideTooltip = function() {
      originalHideTooltip();
      tooltipStructure.classList.add('hidden');
    };

    console.log('SMILES rendering enabled for column:', smilesColumn);

    // Card structure rendering
    cardStack.addEventListener('cardrendered', (e) => {
      const { idx, smilesValue } = e.detail;
      const cardStructure = document.getElementById('card-structure');
      if (!cardStructure) return;

      if (!smilesValue || typeof smilesValue !== 'string' || !smilesValue.trim()) {
        cardStructure.classList.add('hidden');
        return;
      }

      let cardSvg = document.getElementById('card-structure-svg');
      if (!cardSvg) {
        cardSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        cardSvg.id = 'card-structure-svg';
        cardStructure.appendChild(cardSvg);
      }

      cardStructure.classList.remove('hidden');
      cardSvg.innerHTML = '';

      const cardWidthPx = Math.max(120, Math.floor(cardStructure.clientWidth || 216));
      const cardDrawerOptions = { width: cardWidthPx, height: 200, bondThickness: 1.0, compactDrawing: false };

      try {
        if (SmiDrawerCtor) {
          const cardDrawer = new SmiDrawerCtor(cardDrawerOptions);
          cardDrawer.draw(smilesValue, '#card-structure-svg', 'light');
        } else if (SmilesDrawerLib && SmilesDrawerLib.Drawer && SmilesDrawerLib.parse) {
          const cardDrawer = new SmilesDrawerLib.Drawer(cardDrawerOptions);
          SmilesDrawerLib.parse(
            smilesValue,
            (tree) => cardDrawer.draw(tree, 'card-structure-svg', 'light', false),
            (err) => {
              console.warn('Failed to parse SMILES for card:', smilesValue, err);
              cardStructure.classList.add('hidden');
            },
          );
        }
      } catch (err) {
        console.warn('Failed to render SMILES in card:', smilesValue, err);
        cardStructure.classList.add('hidden');
      }
    });
  }
} else if (smilesColumn) {
  console.log('SMILES column specified but not found in columns');
}

// ============================================
// Image Rendering
// ============================================

const imagesColumn = metadata.imagesColumn;
const tooltipImage = document.getElementById('tooltip-image');

if (imagesColumn && columnMeta[imagesColumn]) {
  const imgSize = metadata.imagesTooltipSize || 128;

  // Create img element inside the tooltip image container
  const tooltipImg = document.createElement('img');
  tooltipImg.style.width = imgSize + 'px';
  tooltipImg.style.height = imgSize + 'px';
  tooltipImage.appendChild(tooltipImg);

  const originalShowTooltipImg = showTooltip;
  showTooltip = function(idx) {
    originalShowTooltipImg(idx);

    const imgCol = columns[imagesColumn];
    if (!imgCol) { tooltipImage.classList.add('hidden'); return; }

    const dataUri = imgCol.values[idx];
    if (!dataUri || typeof dataUri !== 'string' || !dataUri.startsWith('data:')) {
      tooltipImage.classList.add('hidden');
      return;
    }

    tooltipImg.src = dataUri;
    tooltipImage.classList.remove('hidden');
  };

  const originalHideTooltipImg = hideTooltip;
  hideTooltip = function() {
    originalHideTooltipImg();
    tooltipImage.classList.add('hidden');
  };

  // Card image rendering
  cardStack.addEventListener('cardrendered', (e) => {
    const { idx } = e.detail;
    const cardImage = document.getElementById('card-image');
    if (!cardImage) return;

    const imgCol = columns[imagesColumn];
    if (!imgCol) { cardImage.classList.add('hidden'); return; }

    const dataUri = imgCol.values[idx];
    if (!dataUri || typeof dataUri !== 'string' || !dataUri.startsWith('data:')) {
      cardImage.classList.add('hidden');
      return;
    }

    let cardImg = cardImage.querySelector('img');
    if (!cardImg) {
      cardImg = document.createElement('img');
      cardImg.style.width = imgSize + 'px';
      cardImg.style.height = imgSize + 'px';
      cardImage.appendChild(cardImg);
    }

    cardImg.src = dataUri;
    cardImage.classList.remove('hidden');
  });

  console.log('Image rendering enabled for column:', imagesColumn, 'size:', imgSize);
} else if (imagesColumn) {
  console.log('Images column specified but not found in columns');
}

// ============================================
// 3Dmol.js loader (shared by proteins + local structures)
// ============================================
let _3dmolLoaded = false;
let _3dmolPromise = null;

function load3Dmol() {
  if (_3dmolPromise) return _3dmolPromise;
  _3dmolPromise = new Promise((resolve, reject) => {
    const script = document.createElement('script');
    script.src = 'https://3Dmol.org/build/3Dmol-min.js';
    script.onload = () => { _3dmolLoaded = true; resolve(); };
    script.onerror = () => reject(new Error('Failed to load 3Dmol.js'));
    document.head.appendChild(script);
  });
  return _3dmolPromise;
}

function render3DStructure(container, structureData, fmt) {
  container.innerHTML = '';
  const viewerDiv = document.createElement('div');
  viewerDiv.className = 'viewer-3d';
  viewerDiv.style.position = 'relative';
  container.appendChild(viewerDiv);

  const viewer = $3Dmol.createViewer(viewerDiv, {
    backgroundColor: 'rgb(26,26,46)',
    antialias: true,
  });
  viewer.addModel(structureData, fmt);
  viewer.setStyle({}, { cartoon: { color: 'spectrum' } });
  viewer.zoomTo();
  viewer.render();
  return viewer;
}

// ============================================
// Protein Rendering (UniProt IDs → AlphaFold)
// ============================================

const proteinColumn = metadata.proteinColumn;

if (proteinColumn && columns[proteinColumn]) {
  const structureCache = new Map();
  const metadataCache = new Map();

  // Tooltip: show UniProt ID as clickable link
  const originalShowTooltipProt = showTooltip;
  showTooltip = function(idx) {
    originalShowTooltipProt(idx);
    const protCol = columns[proteinColumn];
    if (!protCol) return;
    const uid = protCol.values[idx];
    if (!uid || typeof uid !== 'string') return;
    const rows = tooltipContent.querySelectorAll('.row');
    for (const row of rows) {
      const keyEl = row.querySelector('.key');
      const valEl = row.querySelector('.value');
      if (keyEl && valEl && keyEl.textContent.trim() === proteinColumn) {
        valEl.innerHTML = '<a class="uniprot-link" href="https://www.uniprot.org/uniprot/' +
          encodeURI(uid) + '" target="_blank" rel="noopener">' + escapeHtml(uid) + '</a>';
        break;
      }
    }
  };

  // Resolve AlphaFold CIF URL
  const cifUrlCache = new Map();
  async function resolveAlphaFoldUrl(uid) {
    if (cifUrlCache.has(uid)) return cifUrlCache.get(uid);
    try {
      const resp = await fetch('https://alphafold.ebi.ac.uk/api/prediction/' + uid);
      if (!resp.ok) { cifUrlCache.set(uid, null); return null; }
      const entries = await resp.json();
      const entry = Array.isArray(entries) ? entries[0] : entries;
      const url = entry && entry.cifUrl ? entry.cifUrl : null;
      cifUrlCache.set(uid, url);
      return url;
    } catch (e) { cifUrlCache.set(uid, null); return null; }
  }

  async function loadProteinStructure(uid, container) {
    if (structureCache.get(uid) === 'error') {
      container.innerHTML = '<span class="structure-error">No AlphaFold structure<br>for ' + escapeHtml(uid) + '</span>';
      return;
    }
    container.innerHTML = '<span class="structure-loading">Loading 3D structure...</span>';
    structureCache.set(uid, 'loading');

    const cifUrl = await resolveAlphaFoldUrl(uid);
    if (!cifUrl) {
      container.innerHTML = '<span class="structure-error">No AlphaFold structure<br>for ' + escapeHtml(uid) + '</span>';
      structureCache.set(uid, 'error');
      return;
    }

    try {
      await load3Dmol();
      const resp = await fetch(cifUrl);
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      const cifData = await resp.text();
      render3DStructure(container, cifData, 'cif');
      structureCache.set(uid, 'loaded');
    } catch (err) {
      console.warn('Failed to load structure for', uid, err);
      container.innerHTML = '<span class="structure-error">Failed to load structure<br>for ' + escapeHtml(uid) + '</span>';
      structureCache.set(uid, 'error');
    }
  }

  // Fetch UniProt metadata
  async function fetchUniprotMeta(uid, cardBody) {
    if (metadataCache.has(uid)) {
      const cached = metadataCache.get(uid);
      if (cached) renderProtMeta(uid, cached, cardBody);
      return;
    }
    try {
      const resp = await fetch('https://rest.uniprot.org/uniprotkb/' + uid + '.json');
      if (!resp.ok) { metadataCache.set(uid, null); return; }
      const data = await resp.json();
      const meta = {
        name: (data.proteinDescription?.recommendedName?.fullName?.value) ||
              (data.proteinDescription?.submissionNames?.[0]?.fullName?.value) || '',
        organism: data.organism?.scientificName || '',
        gene: data.genes?.[0]?.geneName?.value || '',
        length: data.sequence?.length || '',
      };
      metadataCache.set(uid, meta);
      renderProtMeta(uid, meta, cardBody);
    } catch (e) { metadataCache.set(uid, null); }
  }

  function renderProtMeta(uid, meta, cardBody) {
    const existing = cardBody.querySelector('.protein-metadata');
    if (existing) existing.remove();
    const div = document.createElement('div');
    div.className = 'protein-metadata';
    div.style.cssText = 'margin-top:6px;border-top:1px solid #333;padding-top:6px';
    if (meta) {
      for (const [k, v] of [['Protein', meta.name], ['Organism', meta.organism], ['Gene', meta.gene], ['Length', meta.length ? meta.length + ' aa' : '']]) {
        if (!v) continue;
        const r = document.createElement('div');
        r.className = 'protein-meta-row';
        r.innerHTML = '<span class="meta-key">' + escapeHtml(k) + '</span><span class="meta-val">' + escapeHtml(v) + '</span>';
        div.appendChild(r);
      }
    }
    const links = document.createElement('div');
    links.className = 'protein-meta-row';
    links.style.marginTop = '4px';
    links.innerHTML = '<a class="uniprot-link" href="https://www.uniprot.org/uniprot/' + encodeURI(uid) + '" target="_blank" rel="noopener" style="font-size:11px;margin-right:8px">UniProt</a>' +
      '<a class="uniprot-link" href="https://alphafold.ebi.ac.uk/entry/' + encodeURI(uid) + '" target="_blank" rel="noopener" style="font-size:11px">AlphaFold</a>';
    div.appendChild(links);
    cardBody.appendChild(div);
  }

  // Card rendering
  cardStack.addEventListener('cardrendered', async (e) => {
    const { idx } = e.detail;
    const protCol = columns[proteinColumn];
    if (!protCol) return;
    const uid = protCol.values[idx];
    if (!uid || typeof uid !== 'string') return;

    const cards = cardStack.querySelectorAll('.card');
    const card = cards[cards.length - 1];
    if (!card) return;

    const sc = card.querySelector('.card-structure-container');
    if (sc) {
      sc.classList.remove('hidden');
      sc.style.height = '250px';
      sc.style.background = '#1a1a2e';
      loadProteinStructure(uid, sc);
    }
    const body = card.querySelector('.card-body') || card;
    fetchUniprotMeta(uid, body);
  });

  console.log('Protein rendering enabled for column:', proteinColumn);
} else if (proteinColumn) {
  console.log('Protein column specified but not found in columns');
}

