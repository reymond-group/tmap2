const searchColumn = document.getElementById('search-column');
const searchInput = document.getElementById('search-input');
const searchBtn = document.getElementById('search-btn');
const clearSearchBtn = document.getElementById('clear-search');
const partialMatchCheckbox = document.getElementById('partial-match');
const searchResults = document.getElementById('search-results');

let searchMatches = [];

// Populate search column dropdown with string columns
async function buildSearchColumnOptions() {
  searchColumn.innerHTML = '';
  const searchList = metadata.search || null;

  if (searchList && searchList.length > 0) {
    // Use explicit search column list from Python
    for (const name of searchList) {
      const col = await fetchColumn(name);
      if (!col) continue;
      const opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      searchColumn.appendChild(opt);
    }
  } else {
    // Fall back to all string label columns
    for (const name of labelOptions) {
      const col = await fetchColumn(name);
      if (!col) continue;
      const firstVal = col.values[0];
      if (typeof firstVal !== 'string') continue;

      const opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      searchColumn.appendChild(opt);
    }
    // Add SMILES column if present and not already in labelOptions
    const smilesCol = metadata.smilesColumn;
    if (smilesCol && !labelOptions.includes(smilesCol)) {
      const col = await fetchColumn(smilesCol);
      if (col && typeof col.values[0] === 'string') {
        const opt = document.createElement('option');
        opt.value = smilesCol;
        opt.textContent = smilesCol + ' (SMILES)';
        searchColumn.appendChild(opt);
      }
    }
  }
}
buildSearchColumnOptions();

async function performSearch() {
  const colName = searchColumn.value;
  const query = searchInput.value.trim();
  const partial = partialMatchCheckbox.checked;

  if (!query || !colName) {
    searchResults.textContent = '';
    scatterplot.select([]);
    return;
  }

  const col = await fetchColumn(colName);
  if (!col) {
    searchResults.textContent = 'Column not found';
    return;
  }

  const matches = [];
  const queryLower = query.toLowerCase();

  for (let i = 0; i < col.values.length; i++) {
    const val = String(col.values[i] ?? '');
    const valLower = val.toLowerCase();

    if (partial) {
      if (valLower.includes(queryLower)) matches.push(i);
    } else {
      if (valLower === queryLower) matches.push(i);
    }
  }

  searchMatches = matches;

  if (matches.length === 0) {
    searchResults.textContent = 'No matches found';
    scatterplot.select([]);
  } else {
    searchResults.textContent = matches.length.toLocaleString() + ' match(es) found';
    scatterplot.select(matches);
  }
}

function clearSearch() {
  searchInput.value = '';
  searchResults.textContent = '';
  searchMatches = [];
  scatterplot.select([]);
}

searchBtn.addEventListener('click', performSearch);
searchInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') performSearch();
});
clearSearchBtn.addEventListener('click', clearSearch);

// ============================================
// Filter Sidebar (Embedding Atlas-style)
// ============================================

const fsSections = document.getElementById('fs-sections');
const fsCount = document.getElementById('fs-count');
const fsClearAll = document.getElementById('fs-clear-all');

const filterColumnNames = metadata.filters || [];
const filterState = {};
let filteredIndices = null;

function compactNum(v) {
  if (v >= 1e6) return (v/1e6).toFixed(1).replace(/\\.0$/, '') + 'M';
  if (v >= 1e3) return (v/1e3).toFixed(1).replace(/\\.0$/, '') + 'k';
  return v.toLocaleString();
}

function updateFilterCount() {
  const filtered = filteredIndices ? filteredIndices.length : n;
  if (filteredIndices) {
    fsCount.textContent = compactNum(filtered) + ' / ' + compactNum(n) + ' points';
    fsClearAll.classList.remove('hidden');
  } else {
    fsCount.textContent = compactNum(n) + ' points';
    fsClearAll.classList.add('hidden');
  }
}

async function buildFilterSidebar() {
  if (!filterColumnNames.length) return;

  for (const name of filterColumnNames) {
    const col = await fetchColumn(name);
    if (!col) continue;
    const colUi = (columnMeta[name] && columnMeta[name].ui) || {};
    const displayName = colUi.displayName || name;

    const section = document.createElement('div');
    section.className = 'fs-section';

    const head = document.createElement('div');
    head.className = 'fs-section-head';
    head.innerHTML = '<span>' + escapeHtml(displayName) + '</span><span class="fs-chevron">&#9660;</span>';
    head.addEventListener('click', () => section.classList.toggle('collapsed'));
    section.appendChild(head);

    const body = document.createElement('div');
    body.className = 'fs-section-body';

    if (col.dtype === 'categorical' || typeof col.values[0] === 'string') {
      buildCatSection(name, col, body);
    } else {
      buildNumSection(name, col, body);
    }

    section.appendChild(body);
    fsSections.appendChild(section);
  }

  updateFilterCount();
}

function buildCatSection(colName, col, container) {
  const counts = new Map();
  for (let i = 0; i < col.values.length; i++) {
    const v = String(col.values[i]);
    counts.set(v, (counts.get(v) || 0) + 1);
  }
  const sorted = [...counts.entries()].sort((a, b) => b[1] - a[1]);
  const maxCount = sorted[0][1];
  const showLimit = 15;
  const shown = sorted.slice(0, showLimit);
  const otherEntries = sorted.slice(showLimit);
  const otherCount = otherEntries.reduce((s, [,c]) => s + c, 0);

  function makeRow(value, count, isOther) {
    const row = document.createElement('div');
    row.className = 'fs-bar-row';
    row.dataset.col = colName;
    row.dataset.value = isOther ? '__other__' : value;
    const pct = (count / maxCount * 100).toFixed(1);
    row.innerHTML =
      '<span class="fs-bar-label" title="' + (isOther ? 'other' : escapeHtml(value)) + '">' +
      (isOther ? '<i>(other)</i>' : escapeHtml(value)) + '</span>' +
      '<div class="fs-bar-track"><div class="fs-bar-total" style="width:' + pct + '%"></div>' +
      '<div class="fs-bar-selected" style="width:' + pct + '%"></div></div>' +
      '<span class="fs-bar-count">' + compactNum(count) + ' / ' + compactNum(count) + '</span>';
    row.addEventListener('click', () => toggleCatFilter(colName, row.dataset.value));
    return row;
  }

  for (const [value, count] of shown) {
    container.appendChild(makeRow(value, count, false));
  }
  if (otherCount > 0) {
    container.appendChild(makeRow('', otherCount, true));
  }

  filterState[colName] = {
    type: 'cat', selected: null,
    allValues: sorted,
    otherValues: new Set(otherEntries.map(([v]) => v)),
    maxCount,
  };
}

function buildNumSection(colName, col, container) {
  const vals = [];
  for (let i = 0; i < col.values.length; i++) {
    const v = Number(col.values[i]);
    if (Number.isFinite(v)) vals.push(v);
  }
  if (vals.length === 0) return;

  vals.sort((a, b) => a - b);
  const dataMin = vals[0];
  const dataMax = vals[vals.length - 1];
  if (dataMin === dataMax) return;

  const numBins = 40;
  const binWidth = (dataMax - dataMin) / numBins;
  const bins = new Array(numBins).fill(0);
  for (const v of vals) {
    let idx = Math.floor((v - dataMin) / binWidth);
    if (idx >= numBins) idx = numBins - 1;
    bins[idx]++;
  }
  const maxBin = Math.max(...bins);

  const countLabel = document.createElement('div');
  countLabel.style.cssText = 'font-size:9px;color:#555;margin-bottom:2px;';
  countLabel.textContent = '\\u2191 Count';
  container.appendChild(countLabel);

  const hist = document.createElement('div');
  hist.className = 'fs-histogram';
  hist.dataset.col = colName;

  for (let i = 0; i < numBins; i++) {
    const bar = document.createElement('div');
    bar.className = 'fs-hist-bar';
    bar.style.height = (maxBin > 0 ? (bins[i] / maxBin * 100) : 0) + '%';
    bar.dataset.bin = String(i);
    hist.appendChild(bar);
  }

  const brush = document.createElement('div');
  brush.className = 'fs-hist-brush';
  hist.appendChild(brush);

  const overlay = document.createElement('div');
  overlay.className = 'fs-hist-overlay';
  hist.appendChild(overlay);

  container.appendChild(hist);

  const axis = document.createElement('div');
  axis.className = 'fs-hist-axis';
  axis.innerHTML = '<span>' + formatValue(dataMin) + '</span><span>' + formatValue(dataMax) + '</span>';
  container.appendChild(axis);

  const rangeDisplay = document.createElement('div');
  rangeDisplay.className = 'fs-hist-range';
  container.appendChild(rangeDisplay);

  filterState[colName] = { type: 'num', min: null, max: null, dataMin, dataMax, numBins, binWidth };

  // Brush interaction
  let brushing = false, brushStartX = 0;
  overlay.addEventListener('mousedown', (e) => {
    e.preventDefault();
    brushing = true;
    const rect = hist.getBoundingClientRect();
    brushStartX = e.clientX - rect.left;
    brush.style.display = 'block';
    brush.style.left = brushStartX + 'px';
    brush.style.width = '0px';
  });

  document.addEventListener('mousemove', (e) => {
    if (!brushing) return;
    const rect = hist.getBoundingClientRect();
    let currentX = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
    const left = Math.min(brushStartX, currentX);
    const width = Math.abs(currentX - brushStartX);
    brush.style.left = left + 'px';
    brush.style.width = width + 'px';

    const bars = hist.querySelectorAll('.fs-hist-bar');
    const barW = rect.width / numBins;
    bars.forEach((bar, i) => {
      const bl = i * barW, br = bl + barW;
      bar.classList.toggle('in-brush', br >= left && bl <= left + width);
    });

    const dLeft = dataMin + (left / rect.width) * (dataMax - dataMin);
    const dRight = dataMin + ((left + width) / rect.width) * (dataMax - dataMin);
    rangeDisplay.textContent = formatValue(dLeft) + ' \\u2013 ' + formatValue(dRight);
  });

  document.addEventListener('mouseup', () => {
    if (!brushing) return;
    brushing = false;
    const bw = parseFloat(brush.style.width);
    if (bw < 3) {
      brush.style.display = 'none';
      filterState[colName].min = null;
      filterState[colName].max = null;
      rangeDisplay.textContent = '';
      hist.querySelectorAll('.fs-hist-bar').forEach(b => b.classList.remove('in-brush'));
    } else {
      const rect = hist.getBoundingClientRect();
      const bl = parseFloat(brush.style.left);
      filterState[colName].min = dataMin + (bl / rect.width) * (dataMax - dataMin);
      filterState[colName].max = dataMin + ((bl + bw) / rect.width) * (dataMax - dataMin);
    }
    applyAllFilters();
  });

  overlay.addEventListener('dblclick', () => {
    brush.style.display = 'none';
    filterState[colName].min = null;
    filterState[colName].max = null;
    rangeDisplay.textContent = '';
    hist.querySelectorAll('.fs-hist-bar').forEach(b => b.classList.remove('in-brush'));
    applyAllFilters();
  });
}

function toggleCatFilter(colName, value) {
  const state = filterState[colName];
  if (!state || state.type !== 'cat') return;

  if (!state.selected) {
    state.selected = new Set([value]);
  } else if (state.selected.has(value)) {
    state.selected.delete(value);
    if (state.selected.size === 0) state.selected = null;
  } else {
    state.selected.add(value);
  }

  fsSections.querySelectorAll('.fs-bar-row[data-col="' + colName + '"]').forEach(row => {
    row.classList.toggle('deselected', !!state.selected && !state.selected.has(row.dataset.value));
  });

  applyAllFilters();
}

async function applyAllFilters() {
  let indices = null;

  for (const [colName, state] of Object.entries(filterState)) {
    if (state.type === 'cat' && state.selected) {
      const col = columns[colName];
      if (!col) continue;
      const matching = new Set();
      for (let i = 0; i < col.values.length; i++) {
        const v = String(col.values[i]);
        if (state.selected.has(v)) { matching.add(i); }
        else if (state.selected.has('__other__') && state.otherValues.has(v)) { matching.add(i); }
      }
      indices = indices ? indices.filter(i => matching.has(i)) : [...matching];
    } else if (state.type === 'num' && (state.min !== null || state.max !== null)) {
      const col = columns[colName];
      if (!col) continue;
      const matching = new Set();
      for (let i = 0; i < col.values.length; i++) {
        const v = Number(col.values[i]);
        if (!Number.isFinite(v)) continue;
        if (state.min !== null && v < state.min) continue;
        if (state.max !== null && v > state.max) continue;
        matching.add(i);
      }
      indices = indices ? indices.filter(i => matching.has(i)) : [...matching];
    }
  }

  filteredIndices = indices;
  if (indices !== null) {
    scatterplot.filter(indices);
  } else {
    scatterplot.unfilter();
  }

  updateFilterCount();
  updateBarCounts();
}

function updateBarCounts() {
  const matchSet = filteredIndices ? new Set(filteredIndices) : null;

  for (const [colName, state] of Object.entries(filterState)) {
    if (state.type !== 'cat') continue;
    const col = columns[colName];
    if (!col) continue;

    const filteredCounts = new Map();
    for (let i = 0; i < col.values.length; i++) {
      if (matchSet && !matchSet.has(i)) continue;
      filteredCounts.set(String(col.values[i]), (filteredCounts.get(String(col.values[i])) || 0) + 1);
    }

    fsSections.querySelectorAll('.fs-bar-row[data-col="' + colName + '"]').forEach(row => {
      const value = row.dataset.value;
      let filteredCount, totalCount;
      if (value === '__other__') {
        totalCount = [...state.otherValues].reduce((s, v) => {
          const e = state.allValues.find(([val]) => val === v);
          return s + (e ? e[1] : 0);
        }, 0);
        filteredCount = [...state.otherValues].reduce((s, v) => s + (filteredCounts.get(v) || 0), 0);
      } else {
        const e = state.allValues.find(([v]) => v === value);
        totalCount = e ? e[1] : 0;
        filteredCount = filteredCounts.get(value) || 0;
      }
      const bar = row.querySelector('.fs-bar-selected');
      const countEl = row.querySelector('.fs-bar-count');
      if (bar) bar.style.width = (state.maxCount > 0 ? (filteredCount / state.maxCount * 100).toFixed(1) : 0) + '%';
      if (countEl) countEl.textContent = compactNum(filteredCount) + ' / ' + compactNum(totalCount);
    });
  }
}

function clearAllFilters() {
  for (const state of Object.values(filterState)) {
    if (state.type === 'cat') state.selected = null;
    else if (state.type === 'num') { state.min = null; state.max = null; }
  }
  fsSections.querySelectorAll('.fs-bar-row').forEach(r => r.classList.remove('deselected'));
  fsSections.querySelectorAll('.fs-hist-brush').forEach(b => { b.style.display = 'none'; });
  fsSections.querySelectorAll('.fs-hist-bar').forEach(b => b.classList.remove('in-brush'));
  fsSections.querySelectorAll('.fs-hist-range').forEach(r => { r.textContent = ''; });
  scatterplot.unfilter();
  filteredIndices = null;
  updateFilterCount();
  updateBarCounts();
}

fsClearAll.addEventListener('click', clearAllFilters);

if (filterColumnNames.length > 0) {
  buildFilterSidebar();
}

